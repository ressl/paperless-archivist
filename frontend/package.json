{
  "name": "paperless-archivist-frontend",
  "version": "1.17.1",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.34.1",
  "scripts": {
    "generate:client": "openapi-typescript ../openapi/openapi.yaml -o src/api/schema.ts",
    "lint": "pnpm i18n:check && pnpm contract:routes && pnpm contract:settings && pnpm contract:compose && pnpm generate:client && git diff --exit-code -- src/api/schema.ts",
    "contract:routes": "node ../scripts/verify/router_openapi_contract.mjs",
    "contract:settings": "node ../scripts/verify/runtime_settings_openapi_contract.mjs",
    "contract:compose": "node ../scripts/verify/compose_proxy_contract.mjs --static",
    "contract:compose:rendered": "node ../scripts/verify/compose_proxy_contract.mjs",
    "accessibility:check": "node ../scripts/verify/accessibility_static_check.mjs",
    "i18n:check": "node ../scripts/verify/i18n_translation_parity.mjs",
    "test": "node --test ../scripts/verify/sglang_minimax_m3_contract.test.mjs ../scripts/verify/sglang_minimax_m3_capacity.test.mjs ../scripts/verify/kubernetes_custom_ai_egress_contract.test.mjs ../scripts/verify/kubernetes_monitoring_contract.test.mjs && pnpm test:a11y && pnpm test:i18n",
    "test:a11y": "vitest run --reporter=verbose",
    "test:i18n": "node --test ../scripts/verify/i18n_translation_parity.test.mjs",
    "typecheck": "tsc --noEmit",
    "build": "vite build",
    "dev": "vite"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.0",
    "lucide-react": "^1.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.8.1",
    "vite": "^8.0.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest-axe": "^3.5.9",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.0",
    "jest-axe": "^9.0.0",
    "jsdom": "^29.0.0",
    "openapi-typescript": "^7.10.0",
    "typescript": "^6.0.3",
    "vitest": "^4.0.0",
    "yaml": "^2.8.1"
  },
  "pnpm": {
    "overrides": {
      "esbuild": ">=0.28.1"
    }
  }
}
