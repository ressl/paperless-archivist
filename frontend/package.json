{
  "name": "paperless-archivist-frontend",
  "version": "1.12.1",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.34.1",
  "scripts": {
    "generate:client": "openapi-typescript ../openapi/openapi.yaml -o src/api/schema.ts",
    "accessibility:check": "node ../scripts/verify/accessibility_static_check.mjs",
    "i18n:check": "node ../scripts/verify/i18n_translation_parity.mjs",
    "test:a11y": "vitest run --reporter=verbose",
    "typecheck": "tsc --noEmit",
    "build": "vite build",
    "dev": "vite"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.0",
    "lucide-react": "^1.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.8.1",
    "vite": "^8.0.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest-axe": "^3.5.9",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.0",
    "jest-axe": "^9.0.0",
    "jsdom": "^29.0.0",
    "openapi-typescript": "^7.10.0",
    "typescript": "^6.0.3",
    "vitest": "^4.0.0"
  }
}
