{
  "name": "paperless-archivist-frontend",
  "version": "1.5.4",
  "private": true,
  "type": "module",
  "scripts": {
    "generate:client": "openapi-typescript ../openapi/openapi.yaml -o src/api/schema.ts",
    "accessibility:check": "node ../scripts/verify/accessibility_static_check.mjs",
    "i18n:check": "node ../scripts/verify/i18n_translation_parity.mjs",
    "test:a11y": "vitest run --reporter=verbose",
    "typecheck": "tsc --noEmit",
    "build": "vite build",
    "dev": "vite --host 0.0.0.0"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "lucide-react": "^0.561.0",
    "openapi-fetch": "^0.15.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "recharts": "^3.8.1",
    "typescript": "^5.9.0",
    "vite": "^7.2.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest-axe": "^3.5.9",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "jest-axe": "^9.0.0",
    "jsdom": "^25.0.1",
    "openapi-typescript": "^7.10.0",
    "vitest": "^2.1.9"
  }
}
