# Example env for the dev-local docker-compose overlay.
#
#   cp deploy/compose/.env.dev-local.example deploy/compose/.env.dev-local
#
# The real .env.dev-local is gitignored — never commit secrets.

# --- archivist core ---
POSTGRES_DB=archivist
POSTGRES_USER=archivist
POSTGRES_PASSWORD=dev-local-archivist-pg-password
ARCHIVIST_SECRET_KEY=dev-local-archivist-secret-key-32-bytes-please-change
ARCHIVIST_ADMIN_USERNAME=admin
ARCHIVIST_ADMIN_PASSWORD=dev-local-admin
ARCHIVIST_HTTP_ADDR=0.0.0.0:8080
ARCHIVIST_COOKIE_SECURE=false
ARCHIVIST_OIDC_ENABLED=false
ARCHIVIST_WORKER_CONCURRENCY=2
ARCHIVIST_LOG_LEVEL=debug

# --- paperless-ngx ---
PAPERLESS_DBNAME=paperless
PAPERLESS_DBUSER=paperless
PAPERLESS_DBPASS=dev-local-paperless-pg-password
PAPERLESS_SECRET_KEY=dev-local-paperless-secret-key-please-change
PAPERLESS_ADMIN_USER=admin
PAPERLESS_ADMIN_PASSWORD=dev-local-paperless-admin
PAPERLESS_OCR_LANGUAGE=eng+deu
PAPERLESS_OCR_LANGUAGES="eng deu"
PAPERLESS_TIME_ZONE=Europe/Zurich
PAPERLESS_URL=http://localhost:8000

# --- read-only seeding from an upstream Paperless ---
# Optional. Point this at any reachable Paperless-ngx instance you have an
# API token for, and `scripts/seed-from-prod.py` will pull a varied sample of
# real documents into the local stack. The token is read from the shell env
# only — never put it in this file.
SOURCE_PAPERLESS_URL=https://paperless.example.com
# SOURCE_PAPERLESS_TOKEN= (export in your shell, do not commit)
