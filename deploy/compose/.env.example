POSTGRES_DB=archivist
POSTGRES_USER=archivist
POSTGRES_PASSWORD=change-me-scram-password
ARCHIVIST_SECRET_KEY=change-me-32-bytes-minimum-local-secret
ARCHIVIST_ADMIN_USERNAME=admin
ARCHIVIST_ADMIN_PASSWORD=change-me-admin-password
ARCHIVIST_HTTP_ADDR=0.0.0.0:8080
# Keep false for direct localhost HTTP. The Caddy overlay forces true for TLS.
ARCHIVIST_COOKIE_SECURE=false
ARCHIVIST_OIDC_ENABLED=false
ARCHIVIST_OIDC_ISSUER_URL=https://issuer.example.com
ARCHIVIST_OIDC_CLIENT_ID=
ARCHIVIST_OIDC_CLIENT_SECRET=
ARCHIVIST_OIDC_REDIRECT_URI=http://localhost:8080/api/auth/oidc/callback
ARCHIVIST_OIDC_ADMIN_USERS=
ARCHIVIST_OIDC_DEFAULT_ROLES=viewer
# IdP role assertion (ZITADEL must assert roles into the ID token). Defaults fit
# the archivist-<role> convention; override only if your claim/role names differ.
ARCHIVIST_OIDC_ROLES_CLAIM=urn:zitadel:iam:org:project:roles
ARCHIVIST_OIDC_ROLE_MAPPINGS=archivist-admin=admin,archivist-operator=operator,archivist-reviewer=reviewer,archivist-auditor=auditor,archivist-viewer=viewer
ARCHIVIST_WORKER_CONCURRENCY=2
ARCHIVIST_LOG_LEVEL=info
ARCHIVIST_API_MEMORY_LIMIT=768m
ARCHIVIST_API_MEMORY_RESERVATION=256m
ARCHIVIST_WORKER_MEMORY_LIMIT=1g
ARCHIVIST_WORKER_MEMORY_RESERVATION=512m
EXTERNAL_DATABASE_URL=postgres://archivist:change-me@postgres.example.com:5432/archivist
ARCHIVIST_PUBLIC_HOST=paperless-archivist.example.com
ACME_EMAIL=admin@example.com
