/target/
/frontend/node_modules/
/frontend/dist/
/.env
/.env.*
!.env.example
!*.env.example
/.env.local
/.DS_Store
.idea/
.vscode/
.claude/

# Dev-local stack: real secrets and sample documents pulled from prod must never
# be committed. The `.example` variants are committed (the global ignore
# `.env.*` would otherwise hide them, so re-include them explicitly).
/deploy/compose/.env
!/deploy/compose/.env.example
/deploy/compose/.env.dev-local
!/deploy/compose/.env.dev-local.example
/dev-samples/
/scripts/.dev-local-state.json
/scripts/.dev-local-cookies.txt
